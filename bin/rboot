#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${HOME}/repos/.repo-config"

# repo_name_from <repo_root>
# Echoes the config name for a repo, derived from its git remote origin URL.
repo_name_from() {
  local repo_root="$1"
  local url
  url=$(git -C "$repo_root" config --get remote.origin.url 2>/dev/null) || return 1
  basename -s .git "$url"
}

# apply_config <repo_name> <repo_root> <indent> [required]
# Applies the symlink config (links[]) for a single repo.
apply_config() {
  local repo_name="$1"
  local repo_root="$2"
  local indent="${3:-}"
  local required="${4:-false}"
  local config_file="${CONFIG_DIR}/${repo_name}/setup.json"
  local claude_dir="${CLAUDE_PROJECTS_DIR:-${HOME}/.claude/projects}"

  if [[ ! -f "$config_file" ]]; then
    if [[ "$required" == "true" ]]; then
      echo "Error: no config found for '${repo_name}' at ${config_file}." >&2
      exit 1
    fi
    return
  fi

  echo "${indent}Running setup for ${repo_name}..."

  while IFS= read -r entry; do
    local raw_from raw_to
    raw_from=$(jq -r '.from' <<< "$entry")
    raw_to=$(jq -r '.to'   <<< "$entry")

    # Expand templates; skip entry if either expansion signals failure
    local resolved_from resolved_to
    resolved_from=$(expand_templates "$raw_from" "$repo_root") || continue
    resolved_to=$(expand_templates   "$raw_to"   "$repo_root") || continue

    # [1] claude_projects_dir missing: silent skip
    if [[ "$resolved_to" == "$claude_dir"* && ! -d "$claude_dir" ]]; then
      continue
    fi

    # [2] destination is a real file: warn + skip
    if [[ -f "$resolved_to" && ! -L "$resolved_to" ]]; then
      echo "${indent}  Warning: ${resolved_to} is a real file — skipping" >&2
      continue
    fi

    # [3] idempotent: already correctly symlinked
    if [[ -L "$resolved_to" ]] && \
       [[ "$(readlink "$resolved_to")" == "$resolved_from" ]]; then
      continue
    fi

    # [4] wrong symlink: warn and fall through to overwrite
    if [[ -L "$resolved_to" ]]; then
      echo "${indent}  Warning: replacing existing link at $(basename "$resolved_to") (was: $(readlink "$resolved_to"))" >&2
    fi

    # [5] config-dir source missing: warn + skip (must precede directory-merge check)
    if [[ "$resolved_from" == "$CONFIG_DIR"/* ]] && \
       [[ ! -e "$resolved_from" && ! -L "$resolved_from" ]]; then
      echo "${indent}  Warning: ${resolved_from} not found — skipping" >&2
      continue
    fi

    # [6] destination is a real directory
    if [[ -d "$resolved_to" && ! -L "$resolved_to" ]]; then
      if [[ "$resolved_from" == "$CONFIG_DIR"/* ]]; then
        # Directory merge: symlink only missing children
        local _dotglob_was
        _dotglob_was=$(shopt -p dotglob) || true
        shopt -u dotglob
        for child_path in "$resolved_from"/* "$resolved_from"/.[!.]*; do
          [[ -e "$child_path" || -L "$child_path" ]] || continue
          local child_name
          child_name=$(basename "$child_path")
          local child_target="${resolved_to}/${child_name}"
          if [[ -e "$child_target" || -L "$child_target" ]]; then
            echo "${indent}  Skipped ${child_name} — already exists"
            continue
          fi
          ln -sfn "$child_path" "$child_target"
          echo "${indent}  Symlinked $(basename "$resolved_to")/${child_name} -> ${child_path}"
        done
        eval "$_dotglob_was"
      else
        echo "${indent}  Warning: ${resolved_to} is a real directory and source is external — skipping" >&2
      fi
      continue
    fi

    # [7] create symlink
    local link_flag="-sf"
    if [[ -d "$resolved_from" ]]; then
      link_flag="-sfn"
    elif [[ ! -e "$resolved_from" ]]; then
      link_flag="-sfn"  # external non-existent: default to directory symlink
    fi

    mkdir -p "$(dirname "$resolved_to")"
    ln $link_flag "$resolved_from" "$resolved_to"
    echo "${indent}  Symlinked $(basename "$resolved_to") -> ${resolved_from}"

  done < <(jq -c '.links[]?' "$config_file")
}

usage() {
  cat <<'EOF'
Usage:
  rboot run              Apply symlink config for the current repo (+ nested repos)
  rboot add <path>...    Move path(s) into the rboot config and replace with symlinks
  rboot help             Show this help
EOF
}

# require_env — guards + identity. Called only by command bodies (NOT at file
# scope), so help works outside a git repo.
require_env() {
  if [[ ! -d "$CONFIG_DIR" ]]; then
    echo "Error: config directory not found at ${CONFIG_DIR}." >&2
    echo "       Create it with: mkdir -p ${CONFIG_DIR}" >&2
    exit 1
  fi
  git rev-parse --is-inside-work-tree &>/dev/null || { echo "Error: not inside a git repository." >&2; exit 1; }
  git config --get remote.origin.url &>/dev/null || { echo "Error: no remote 'origin' configured." >&2; exit 1; }
  command -v jq &>/dev/null || { echo "Error: jq is required but not installed. Run: brew install jq" >&2; exit 1; }
  REPO_NAME=$(repo_name_from ".") || { echo "Error: could not determine repository name." >&2; exit 1; }
  [[ -n "$REPO_NAME" ]] || { echo "Error: could not determine repository name." >&2; exit 1; }
  [[ "$REPO_NAME" =~ ^[a-zA-Z0-9._-]+$ ]] || { echo "Error: unsafe repository name '${REPO_NAME}' (must match [a-zA-Z0-9._-]+)." >&2; exit 1; }
  REPO_ROOT=$(cd "$(git rev-parse --show-toplevel)" && pwd -P) || { echo "Error: could not resolve repository root." >&2; exit 1; }
}

# resolve_rel — print repo-root-relative path; nonzero if missing/outside.
resolve_rel() {
  local arg="$1" abs base dir
  if [[ -d "$arg" ]]; then
    abs=$(cd "$arg" && pwd -P) || return 1
  elif [[ -e "$arg" || -L "$arg" ]]; then
    base=$(basename "$arg")
    dir=$(cd "$(dirname "$arg")" && pwd -P) || return 1
    abs="$dir/$base"
  else
    return 2
  fi
  local rel="${abs#"$REPO_ROOT"/}"
  if [[ "$abs" == "$REPO_ROOT" || "$rel" == "$abs" ]]; then return 3; fi
  [[ "$REPO_ROOT/$rel" == "$abs" ]] || return 3
  printf '%s\n' "$rel"
}

# update_config <cfg_path> <rel>
# Appends { "from": "~/repos/.repo-config/<REPO_NAME>/<rel>", "to": "{{repo_root}}/<rel>" }
# to links[] if not already present. Atomic write.
update_config() {
  local cfg="$1" rel="$2" tmp
  local from_val="~/repos/.repo-config/${REPO_NAME}/${rel}"
  local to_val="{{repo_root}}/${rel}"
  tmp=$(mktemp "${cfg}.XXXXXX") || return 1
  if jq --arg from "$from_val" --arg to "$to_val" '
        .links = (.links // [])
        | if (.links | map(select(.from == $from and .to == $to)) | length) > 0
          then .
          else .links += [{"from": $from, "to": $to}]
          end
      ' "$cfg" > "$tmp"; then
    mv "$tmp" "$cfg"
  else
    rm -f "$tmp"; return 1
  fi
}

# add_one — validate-then-mutate, set -e-safe.
add_one() {
  local arg="$1" rel dest src cfg
  if [[ -L "$arg" ]]; then echo "Skip: '$arg' is already a symlink (already managed by rboot)." >&2; return 1; fi
  if [[ ! -e "$arg" ]]; then echo "Error: '$arg' does not exist." >&2; return 1; fi
  rel=$(resolve_rel "$arg") || { echo "Error: '$arg' is outside the repository." >&2; return 1; }
  dest="${CONFIG_DIR}/${REPO_NAME}/${rel}"
  src="${REPO_ROOT}/${rel}"
  if [[ -e "$dest" || -L "$dest" ]]; then
    echo "Error: destination already exists: ${dest} (refusing to clobber)." >&2; return 1; fi

  cfg="${CONFIG_DIR}/${REPO_NAME}/setup.json"
  mkdir -p "${CONFIG_DIR}/${REPO_NAME}"
  [[ -f "$cfg" ]] || printf '{\n    "links": []\n}\n' > "$cfg"

  mkdir -p "$(dirname "$dest")"
  if ! mv "$src" "$dest"; then echo "Error: failed to move ${src} -> ${dest}." >&2; return 1; fi

  mkdir -p "$(dirname "$src")"
  if ! ln -sfn "$dest" "$src"; then
    echo "Error: failed to create symlink; rolling back move." >&2; mv "$dest" "$src"; return 1; fi

  if ! update_config "$cfg" "$rel"; then
    echo "Error: failed to update ${cfg}; rolling back move." >&2
    rm -f "$src"
    mv "$dest" "$src"
    return 1
  fi

  if git -C "$REPO_ROOT" ls-files --error-unmatch -- "$rel" &>/dev/null; then
    echo "Warning: '${rel}' was git-tracked; the symlink will now show as a change. Update .gitignore yourself if desired." >&2; fi

  local from_display="~/repos/.repo-config/${REPO_NAME}/${rel}"
  echo "Added ${rel} -> ${from_display}"
}

# cmd_add — batch with per-path continue.
cmd_add() {
  require_env
  [[ $# -ge 1 ]] || { echo "Error: 'add' requires at least one path." >&2; usage >&2; exit 1; }
  local rc=0
  for arg in "$@"; do
    add_one "$arg" || rc=1
  done
  return "$rc"
}

# encode_claude_path <absolute-path>
# Converts an absolute path to its Claude project directory name by replacing
# all / and . with -.  e.g. /a/b/repo/.worktrees/x → -a-b-repo--worktrees-x
encode_claude_path() {
  local p="${1//\//-}"
  printf '%s\n' "${p//./-}"
}

# _MAIN_ROOT / _MAIN_ROOT_FAILED — cached worktree state, computed once per run.
_MAIN_ROOT=""
_MAIN_ROOT_FAILED=false

# _ensure_main_root — populates _MAIN_ROOT or sets _MAIN_ROOT_FAILED.
# Returns 1 if derivation fails (warning already printed).
_ensure_main_root() {
  [[ "$_MAIN_ROOT_FAILED" == "true" ]] && return 1
  [[ -n "$_MAIN_ROOT" ]] && return 0
  local mr
  mr=$(git worktree list --porcelain | awk '/^worktree/{print $2; exit}')
  if [[ -z "$mr" ]]; then
    echo "  Warning: could not determine main worktree root — skipping worktree link entries" >&2
    _MAIN_ROOT_FAILED=true; return 1
  fi
  mr=$(cd "$mr" && pwd -P) || {
    echo "  Warning: could not resolve main worktree root — skipping worktree link entries" >&2
    _MAIN_ROOT_FAILED=true; return 1
  }
  _MAIN_ROOT="$mr"
}

# expand_templates <string> <repo_root>
# Expands template variables in <string>. Prints expanded value to stdout.
# Returns 1 (no output) to signal "skip this entry":
#   - worktree var used outside a worktree
#   - worktree list derivation fails
#   - unknown template variable found
expand_templates() {
  local str="$1" repo_root="$2"
  local claude_dir="${CLAUDE_PROJECTS_DIR:-${HOME}/.claude/projects}"

  # Expand leading ~
  str="${str/#\~/$HOME}"

  # Substitute non-worktree variables
  str="${str//\{\{repo_root\}\}/$repo_root}"
  str="${str//\{\{claude_projects_dir\}\}/$claude_dir}"

  # Handle worktree-only variables
  if [[ "$str" == *"{{worktree_encoded}}"* || "$str" == *"{{main_encoded}}"* ]]; then
    # Must be inside a worktree (.git is a file, not a directory)
    if [[ ! -f "${REPO_ROOT}/.git" ]]; then
      return 1  # silent skip
    fi
    _ensure_main_root || return 1
    local worktree_encoded main_encoded
    worktree_encoded=$(encode_claude_path "$REPO_ROOT")
    main_encoded=$(encode_claude_path "$_MAIN_ROOT")
    str="${str//\{\{worktree_encoded\}\}/$worktree_encoded}"
    str="${str//\{\{main_encoded\}\}/$main_encoded}"
  fi

  # Detect remaining unknown variables
  if [[ "$str" =~ \{\{[a-zA-Z0-9_]+\}\} ]]; then
    echo "  Warning: unknown template variable in '${str}' — skipping entry" >&2
    return 1
  fi

  printf '%s\n' "$str"
}

# cmd_run — apply symlink config for current repo + nested repos.
cmd_run() {
  require_env

  apply_config "$REPO_NAME" "$REPO_ROOT" "" "true"

  local applied_names=""
  while IFS= read -r gitpath; do
    sub_root=$(dirname "$gitpath")
    sub_root=$(cd "$sub_root" && pwd -P) || continue
    sub_name=$(repo_name_from "$sub_root") || continue
    [[ -n "$sub_name" ]] || continue
    [[ "$sub_name" != "$REPO_NAME" ]] || continue
    case " $applied_names " in *" $sub_name "*) continue ;; esac
    applied_names="$applied_names $sub_name"
    apply_config "$sub_name" "$sub_root" "  "
  done < <(find "$REPO_ROOT" -mindepth 2 \
             -path '*/node_modules/*' -prune -o \
             -path "$REPO_ROOT/.worktrees/*" -prune -o \
             -name .git -print 2>/dev/null)

  echo "Done."
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  case "${1:-}" in
    run)             shift;         cmd_run ;;
    add)             shift;         cmd_add "$@" ;;
    -h|--help|help)  usage ;;
    "")              usage ;;
    *)               echo "Error: unknown command '$1'." >&2; usage >&2; exit 1 ;;
  esac
fi
